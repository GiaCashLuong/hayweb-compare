{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/cron-hayweb",
      "schedule": "0 23 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/cron-hayweb",
      "destination": "https://jllirmrpkayiyajwebbr.supabase.co/functions/v1/site1-cron-hayweb"
    }
  ],
  "redirects": [
    {
      "source": "/((?!api/).*)",
      "destination": "https://hayweb.vn/kiemtra",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
